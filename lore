def _sandy_home(args) -> str:
    return (getattr(args, "sandy_home", None)
            or os.environ.get("SANDY_HOME") or DEFAULT_SANDY_HOME)


def _read_secrets(args):
    """Parse `KEY=value` from `$SANDY_HOME/{.secrets,config}` — sandy's privileged-
    tier credential store, read host-side. Tolerant: skips blanks/comments/malformed
    lines, strips an optional `export ` and surrounding quotes. `.secrets` wins."""
    out = {}
    home = _sandy_home(args)
    for fn in (".secrets", "config"):
        path = os.path.join(home, fn)
        if not os.path.isfile(path):
            continue
        for line in _read_text(path).splitlines():
            line = line.strip()
            if line.startswith("export "):
                line = line[len("export "):].strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, _, v = line.partition("=")
            k = k.strip()
            if k and k not in out:
                out[k] = v.strip().strip('"').strip("'")
    return out


def _resolve_secret(name, args):
    return os.environ.get(name) or _read_secrets(args).get(name)


def _auth_headers(args):
    """Anthropic auth headers, or None if no API key resolves. ONLY ANTHROPIC_API_KEY
    is honored. A Claude Code subscription OAuth token (CLAUDE_CODE_OAUTH_TOKEN) is
    deliberately NOT accepted: routing it to /v1/messages from a non-Claude-Code
    client violates Anthropic's Consumer Terms and is actively enforced (documented
    account bans). Subscription-only users should generate an API key. See SPEC §8."""
    key = _resolve_secret("ANTHROPIC_API_KEY", args)
    if key:
        return {"x-api-key": key}
    return None


def llm_available(args) -> bool:
    return LLM_RUNNER is not None or _auth_headers(args) is not None


def call_llm(prompt, args, model=None) -> str:
    if LLM_RUNNER is not None:
        return LLM_RUNNER(prompt, model)
    headers = _auth_headers(args)
    if headers is None:
        raise LLMUnavailable(
            "no ANTHROPIC_API_KEY — set it in the environment or $SANDY_HOME/.secrets")
    model = model or os.environ.get("SANDY_MODEL") or LLM_DEFAULT_MODEL
    body = json.dumps({
        "model": model,
        "max_tokens": LLM_MAX_TOKENS,
        "messages": [{"role": "user", "content": prompt}],
    }).encode("utf-8")
    req = urllib.request.Request(ANTHROPIC_API_URL, data=body, method="POST")
    req.add_header("content-type", "application/json")
    req.add_header("anthropic-version", ANTHROPIC_VERSION)
    for k, v in headers.items():
        req.add_header(k, v)
    try:
        with urllib.request.urlopen(req, timeout=LLM_TIMEOUT_S) as resp:
            data = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        detail = ""
        try:
            detail = json.loads(e.read().decode("utf-8")).get("error", {}).get("message", "")
        except Exception:  # pragma: no cover - best-effort error-body parse
            pass
        raise LLMError("Claude API HTTP %d%s" % (e.code, (": " + detail) if detail else ""))
    except (urllib.error.URLError, TimeoutError, OSError) as e:
        raise LLMError("Claude API request failed: %s" % e)
    if data.get("stop_reason") == "refusal":
        raise LLMError("Claude declined the request (refusal)")
    return "".join(b.get("text", "") for b in data.get("content", [])
                   if b.get("type") == "text").strip()


def _llm_model(args):
    return getattr(args, "model", None)


# ── §11a  summarize ──────────────────────────────────────────────────────────
_SUMMARIZE_HEAD = (
    "You are summarizing the persistent memory an AI coding agent has accumulated.\n"
    "Produce a concise digest of what's been learned, grouped by theme. Call out any\n"
    "contradictions between memories explicitly. Output GitHub-flavored markdown; do\n"
    "not invent facts beyond the memories below.\n\n=== MEMORIES ===\n")

_REDUCE_HEAD = (
    "Below are partial summaries of an AI agent's accumulated memory. Merge them into\n"
    "one coherent digest, grouped by theme, preserving any flagged contradictions and\n"
    "removing redundancy. Output GitHub-flavored markdown.\n\n=== PARTIAL SUMMARIES ===\n")


def _item_block(it) -> str:
    head = "## %s  [%s/%s/%s]" % (it.title, it.agent, it.project, it.type or "unknown")
    desc = ("\n_%s_" % it.description) if it.description else ""
    return "%s%s\n\n%s" % (head, desc, (it.body or "").strip())


def _chunk_blocks(blocks, budget):
    """Greedily pack blocks into chunks under `budget` chars. A single oversized
    block gets its own chunk (we never split mid-memory)."""
    chunks, cur, cur_len = [], [], 0
    for b in blocks:
        if cur and cur_len + len(b) > budget:
            chunks.append(cur)
            cur, cur_len = [], 0
        cur.append(b)
        cur_len += len(b)
    if cur:
        chunks.append(cur)
    return chunks


def cmd_summarize(args):
    items = collect_items(args)
    if not items:
        if args.json:
            emit_json({"summary": "", "items": 0, "model": _llm_model(args)})
        else:
            print("Nothing to summarize (no memories matched).")
        return EXIT_OK
    if not llm_available(args):
        return die("no ANTHROPIC_API_KEY — set it in env or $SANDY_HOME/.secrets; "
                   "the read-only commands work without it", EXIT_RUNTIME, args.json)
    model = _llm_model(args)
    blocks = [_item_block(it) for it in
              sorted(items, key=lambda i: (i.project, i.agent, i.title.lower()))]
    chunks = _chunk_blocks(blocks, SUMMARIZE_CHAR_BUDGET)
    try:
        partials = [call_llm(_SUMMARIZE_HEAD + "\n\n".join(c), args, model) for c in chunks]
        summary = (partials[0] if len(partials) == 1
                   else call_llm(_REDUCE_HEAD + "\n\n---\n\n".join(partials), args, model))
    except LLMUnavailable as e:
        return die(str(e), EXIT_RUNTIME, args.json)
    except LLMError as e:
        return die(str(e), EXIT_RUNTIME, args.json)
    if args.json:
        emit_json({"summary": summary, "items": len(items),
                   "chunks": len(chunks), "model": model})
        return EXIT_OK
    print(summary)
    return EXIT_OK


# ── §11b  relevant ───────────────────────────────────────────────────────────
_EXPLAIN_HEAD = (
    "An AI coding agent is working in project '%s'. Below are memories from OTHER\n"
    "projects/agents that a token-overlap heuristic flagged as possibly relevant.\n"
    "For each, give a one-line rationale for whether it actually applies here, then\n"
    "rank them most- to least-relevant. Advisory only — do not propose copying.\n"
    "Output markdown.\n\n=== TARGET PROJECT CONTEXT ===\n%s\n\n=== CANDIDATES ===\n%s\n")


def _candidate_line(it, score) -> str:
    desc = (" — %s" % it.description) if it.description else ""
    return "- [%.2f] %s [%s/%s/%s]%s" % (
        score, it.title, it.agent, it.project, it.type or "unknown", desc)


def cmd_relevant(args):
    items = collect_items_all(args)
    target = [it for it in items
              if args.project in (it.project, it.project_slug)]
    if not target:
        return die("no memories found for project '%s' to compare against"
                   % args.project, EXIT_RUNTIME, args.json)
    target_slugs = set(it.project_slug for it in target)
    candidates = [it for it in items if it.project_slug not in target_slugs]
    ranked = rank_relevant(target, candidates, args.top)

    if args.explain and ranked:
        if not llm_available(args):
            return die("no ANTHROPIC_API_KEY — `--explain` needs it; drop `--explain` "
                       "for the offline ranked list", EXIT_RUNTIME, args.json)
        ctx = "\n".join("- %s%s" % (it.title, (": " + it.description) if it.description else "")
                        for it in target[:30])
        cand = "\n".join(_candidate_line(it, s) for it, s in ranked)
        try:
            explanation = call_llm(
                _EXPLAIN_HEAD % (args.project, ctx, cand), args, _llm_model(args))
        except LLMUnavailable as e:
            return die(str(e), EXIT_RUNTIME, args.json)
        except LLMError as e:
            return die(str(e), EXIT_RUNTIME, args.json)
    else:
        explanation = None

    if args.json:
        emit_json({"project": args.project,
                   "candidates": [dict(it.to_json_dict(), score=round(s, 4))
                                  for it, s in ranked],
                   "count": len(ranked),
                   "explanation": explanation})
        return EXIT_OK
    if not ranked:
        print("No memories from other projects look relevant to '%s'." % args.project)
        return EXIT_OK
    print("Possibly relevant to '%s' (advisory — `copy` is the explicit step):"
          % args.project)
    for it, s in ranked:
        print(_candidate_line(it, s))
    if explanation:
        print("\n— rationale —\n")
        print(explanation)
    return EXIT_OK


# ── §12  argparse + main ────────────────────────────────────────────────────
def build_parser():
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--agent", help="restrict to agent(s), comma-separated")
    common.add_argument("--source", choices=["sandbox", "host"], default="sandbox")
    common.add_argument("--sandboxes-root", dest="sandboxes_root",
                        help="override sandbox discovery (tests / non-default SANDY_HOME)")
    common.add_argument("--sandy-home", dest="sandy_home")
    common.add_argument("--include-instructions", dest="include_instructions",
                        action="store_true", help="(v0b — currently a no-op)")
    common.add_argument("--json", action="store_true")
    common.add_argument("-v", dest="v", action="count", default=0)
    common.add_argument("-q", dest="q", action="count", default=0)

    parser = argparse.ArgumentParser(prog="lore", description="One lens over agent memory.")
    parser.add_argument("--version", action="version",
                        version="lore %s (%s)" % (LORE_VERSION, LORE_COMMIT or "dev"))
    sub = parser.add_subparsers(dest="cmd")

    p = sub.add_parser("ls", parents=[common], aliases=["list"], help="list memories")
    p.add_argument("--type")
    p.add_argument("--project")
    p.add_argument("--sort", choices=["name", "mtime"], default="name",
                   help="within each project: name = A–Z by title (default), mtime = newest first")
    p.set_defaults(func=cmd_ls)

    p = sub.add_parser("search", parents=[common], help="search memories")
    p.add_argument("query")
    p.add_argument("--type")
    p.add_argument("--project")
    p.add_argument("--field", choices=["title", "description", "body", "all"], default="all")
    p.set_defaults(func=cmd_search)

    p = sub.add_parser("show", parents=[common], help="show a memory + its links")
    p.add_argument("title")
    p.add_argument("--project")
    p.add_argument("--depth", type=int, default=1)
    p.set_defaults(func=cmd_show)

    p = sub.add_parser("graph", parents=[common], help="render the link graph")
    p.add_argument("--project")
    p.add_argument("--dot", action="store_true")
    p.add_argument("--cross-project", dest="cross_project", action="store_true")
    p.set_defaults(func=cmd_graph)

    p = sub.add_parser("stats", parents=[common], help="counts, mismatches, dangling links")
    p.set_defaults(func=cmd_stats)

    p = sub.add_parser("export", parents=[common], help="consolidated digest")
    p.add_argument("--md", action="store_true", help="markdown (default)")
    p.add_argument("--project")
    p.set_defaults(func=cmd_export)

    p = sub.add_parser("summarize", parents=[common],
                       help="LLM digest of what's been learned (needs an Anthropic API key)")
    p.add_argument("--type")
    p.add_argument("--project")
    p.add_argument("--model", help="LLM model (else $SANDY_MODEL, else claude default)")
    p.set_defaults(func=cmd_summarize)

    p = sub.add_parser("relevant", parents=[common],
                       help="memories from elsewhere that may apply to a project")
    p.add_argument("project", help="target project (label or slug)")
    p.add_argument("--top", type=int, default=10, help="shortlist size (default 10)")
    p.add_argument("--explain", action="store_true",
                   help="LLM rerank with rationales (needs an Anthropic API key)")
    p.add_argument("--model", help="LLM model (else $SANDY_MODEL, else claude default)")
    p.set_defaults(func=cmd_relevant)

    p = sub.add_parser("sessions", parents=[common], help="list session profiles (transcripts)")
    p.add_argument("--project")
    p.add_argument("--sort", choices=["title", "started", "duration", "events"], default="title",
                   help="within each project: title = A–Z (default), started/duration/events otherwise")
    p.set_defaults(func=cmd_sessions)

    p = sub.add_parser("session", parents=[common], help="characterize one session (id prefix or title)")
    p.add_argument("id", help="session id (or prefix), or a title substring")
    p.add_argument("--project")
    p.set_defaults(func=cmd_session)

    return parser


def main(argv) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if not getattr(args, "cmd", None):
        parser.print_help()
        return EXIT_USAGE
    args.verbosity = getattr(args, "v", 0) - getattr(args, "q", 0)

    if args.agent:
        agents = set(a.strip() for a in args.agent.split(",") if a.strip())
        bad = agents - KNOWN_AGENTS
        if bad:
            return die("unknown agent(s): %s (known: %s)"
                       % (", ".join(sorted(bad)), ", ".join(sorted(KNOWN_AGENTS))),
                       EXIT_USAGE, args.json)
        args.agent = agents
    else:
        args.agent = None

    if args.source == "host":
        return die("--source host is not implemented in v0", EXIT_RUNTIME, args.json)
    if getattr(args, "include_instructions", False):
        warn("--include-instructions is not implemented until v0b (ignored)", args, 1)

    try:
        code = args.func(args)
        emit_coverage(args)  # -v note on stderr; harmless for --json (stdout-only)
        return code
    except BrokenPipeError:
        return EXIT_OK
    except Exception as e:  # pragma: no cover - last-resort guard
        if args.verbosity >= 1:
            raise
        return die(str(e), EXIT_RUNTIME, args.json)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
