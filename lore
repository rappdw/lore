# ── §10  Token-overlap scorer (SPEC §6.1 stage 1) ───────────────────────────
# Deterministic, offline, no LLM. Built here for `relevant`'s shortlist; reused
# by curation (dedup clustering) in a later increment. Shingle-Jaccard over
# title+description+body, lowercased + destopworded.

# A small, conventional English stoplist — enough to keep shingles signal-bearing
# without pulling in a corpus. Kept short on purpose (single-file, no data files).
_STOPWORDS = frozenset("""
a an and are as at be but by for from has have if in into is it its of on or
that the their then there these this to was were will with you your we our
""".split())

_TOKEN_RE = re.compile(r"[a-z0-9]+")


def tokenize(text: str):
    """Lowercase word tokens, stopwords and 1-char tokens dropped."""
    if not text:
        return []
    return [t for t in _TOKEN_RE.findall(text.lower())
            if len(t) > 1 and t not in _STOPWORDS]


def shingles(text, n_min: int = 2, n_max: int = 3):
    """Set of n-gram shingles (n in [n_min, n_max]). Falls back to unigrams when
    the token stream is too short to form any n-gram, so tiny texts still score."""
    toks = tokenize(text)
    if not toks:
        return set()
    out = set()
    for n in range(n_min, n_max + 1):
        for i in range(len(toks) - n + 1):
            out.add(tuple(toks[i:i + n]))
    if not out:  # fewer than n_min tokens → compare on the unigrams we have
        out = {(t,) for t in toks}
    return out


def jaccard(a: set, b: set) -> float:
    if not a and not b:
        return 0.0
    inter = len(a & b)
    if not inter:
        return 0.0
    return inter / len(a | b)


def _item_text(it) -> str:
    parts = [it.title or "", it.description or "", it.body or ""]
    return "\n".join(p for p in parts if p)


def _shingle_index(items):
    """Precompute each item's shingle set once (clustering/ranking is O(n²))."""
    return [(it, shingles(_item_text(it))) for it in items]


def rank_relevant(target_items, candidate_items, top_n: int):
    """Score each candidate by its MAX shingle-Jaccard against the target corpus
    (SPEC §6.2). Returns [(item, score)] sorted desc, score>0 only, top_n kept."""
    target_sh = [s for _, s in _shingle_index(target_items) if s]
    if not target_sh:
        return []
    scored = []
    for it, sh in _shingle_index(candidate_items):
        if not sh:
            continue
        best = max(jaccard(sh, ts) for ts in target_sh)
        if best > 0:
            scored.append((it, best))
    scored.sort(key=lambda r: (-r[1], -r[0].mtime, r[0].title.lower()))
    return scored[:top_n]


# ── §11  LLM integration (opt-in; SPEC §8) ──────────────────────────────────
# `summarize` / `relevant --explain` call the Anthropic Messages API directly over
# stdlib HTTP (urllib) — no third-party SDK, so the single-file/stdlib invariant
# holds. lore runs HOST-side, where the agent CLIs (claude/codex/…) usually aren't
# installed, so we authenticate with an API key rather than shelling out. We do NOT
# accept a Claude Code OAuth token for the API (ToS-prohibited, enforced — §8). The
# read-only core never calls this. Tests inject LLM_RUNNER to stub the model.

